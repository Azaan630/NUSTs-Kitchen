# Database Configuration
DB_HOST=db
DB_USER=root
DB_PASSWORD=your_secure_password_here
DB_NAME=mess_db
DB_PORT=3306

# Internal backend URL (used by containers to communicate internally)
BACKEND_URL=http://backend:8000

# Public backend URL (accessed by client browsers for file downloads)
PUBLIC_BACKEND_URL=http://localhost:8000

# Flet Frontend OAuth Redirect URL
OAUTH_REDIRECT_URL=http://localhost:8550/oauth_callback

# Security Config (CORS allowed origins, comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8550,http://localhost:8501

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT Secret (generate a random 64-char hex string)
JWT_SECRET=generate_a_random_64_char_hex_string_here_change_me_in_production
